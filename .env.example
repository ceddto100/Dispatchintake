# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook ingestion (Make.com → /api/intakes/webhook)
MAKE_WEBHOOK_SECRET=replace-with-a-long-random-string

# Branding (optional)
NEXT_PUBLIC_APP_NAME=Dispatch Intake
NEXT_PUBLIC_APP_BRAND=Dispatch Intake

# Demo mode: when Supabase env vars are missing, app runs off in-memory seed data
# Set to "true" to force demo even if env vars are present
NEXT_PUBLIC_DEMO_MODE=false
